# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

output/

# Benchmark fixtures regenerated by scripts/export_ddr_sandbox.py against ~/projects/ddr.
# Not source — regenerate with `uv run python scripts/export_ddr_sandbox.py`.
# Only ignore root-level and examples-level fixtures/ — tests/fixtures/ is tracked source.
/fixtures/
examples/fixtures/

# Agent notes are tracked (ARCHITECTURE.md, skills/, specs/) — only ignore transient state
.claude/worktrees/
.claude/**/.regenerate-state.json
.claude/settings.local.json

# Throwaway BURN API exploration directory
spike_backward/

# Editor / OS noise
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Python bytecode cache from scripts/*.py run under DDR's uv venv
__pycache__/

.cargo/
.ddrs/
ddrs.yaml
